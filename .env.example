#
# Copy to `.env.local` and fill in secrets.
#

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trading_site?schema=public"

APP_BASE_URL="http://localhost:3000"

# Auth
JWT_SECRET="change-this"
TWO_FACTOR_ENCRYPTION_KEY="change-this-to-a-32-byte-secret"

# Stripe (Deposits/Withdrawals)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_SUCCESS_URL=""
STRIPE_CANCEL_URL=""

# Alpaca (Live or Paper trading)
ALPACA_KEY_ID=""
ALPACA_SECRET_KEY=""
ALPACA_PAPER="true"
ALPACA_BASE_URL="https://paper-api.alpaca.markets"

# KYC provider (hook verification, if you integrate one)
KYC_WEBHOOK_SECRET=""

